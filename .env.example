# ─── OpenAI ───────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key-here

# Model options (pick one):
#   gpt-4o-mini   ← recommended (cheap + smart)
#   gpt-4o        ← more capable, higher cost
#   gpt-3.5-turbo ← cheapest, less reliable for tool use
OPENAI_MODEL=gpt-4o-mini

# ─── KSA-SAM Backend ──────────────────────────────────────────
SAM_BASE_URL=https://sam-be.idzone.app/api/v2

# ─── Session ──────────────────────────────────────────────────
# Max conversation turns to keep in memory (prevents token bloat)
MAX_HISTORY_TURNS=20
